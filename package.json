{
  "name": "concrete-calculator-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "extract:adobe-production-rates": "node tools/data-extraction/adobe/extract_adobe_pdf.cjs",
    "extract:production-rates": "python tools/data-extraction/extract_chapter5.py --all-divisions",
    "normalize:production-rates": "python tools/data-extraction/normalize_raw.py",
    "validate:production-rates": "python tools/data-extraction/validate_production_rates.py --all-stages",
    "ai-review:production-rates": "python tools/data-extraction/ai_review_production_rates.py",
    "promote:production-rates": "python tools/data-extraction/promote_reviewed_rates.py",
    "bootstrap:production-rates": "node --import tsx scripts/bootstrapApprovedFromManualRates.ts",
    "import:adobe-production-rates": "node --import tsx scripts/importAdobeFinalReviewedProductionRates.ts",
    "generate:adobe-rejected-recovery": "node --import tsx scripts/generateAdobeRejectedRecoveryReport.ts",
    "recover:adobe-production-rates": "node --import tsx scripts/recoverAdobeRejectedProductionRates.ts",
    "generate:production-rates": "node --import tsx scripts/generateProductionRateSeeds.ts",
    "generate:canonical-production-rates": "node --import tsx scripts/generateCanonicalProductionRateLibrary.ts",
    "preview": "vite preview",
    "analyze": "cross-env ANALYZE=true vite build",
    "serve:prod": "node csp-server.cjs",
    "upload-sounds": "tsx scripts/uploadSounds.ts",
    "generate:favicons": "node scripts/generateFavicons.mjs",
    "qa:seed-gates": "tsx scripts/qa/seed-tier-gate-data.ts",
    "qa:cleanup-gates": "tsx scripts/qa/cleanup-tier-gate-data.ts",
    "qa:e2e-gates": "playwright test --project=tier-gates --headed && tsx scripts/qa/run-tier-gate-checks.ts",
    "qa:e2e-gates:debug": "playwright test --project=tier-gates --headed --debug",
    "qa:gates": "npm run qa:seed-gates && npm run qa:e2e-gates"
  },
  "dependencies": {
    "@adobe/pdfservices-node-sdk": "^4.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.3.4",
    "@supabase/supabase-js": "^2.39.7",
    "@tailwindcss/typography": "^0.5.10",
    "@tailwindcss/vite": "^4.3.0",
    "@xyflow/react": "^12.11.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.6.7",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^3.3.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.0.8",
    "helmet": "^7.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.5.28",
    "lucide-react": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.3",
    "react-hook-form": "^7.51.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "react-to-print": "^3.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "workbox-window": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.58.2",
    "@squoosh/lib": "^0.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.6",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.18",
    "cross-env": "^10.1.0",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "imagemin": "^9.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-webp": "^8.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.35",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.2",
    "tailwindcss": "^3.4.19",
    "to-ico": "^1.1.5",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4.1.7"
  }
}
