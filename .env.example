# Supabase (frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (frontend — publishable key only; never put secret keys in VITE_* vars)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
VITE_APP_URL=http://localhost:5173

# Entitlements (optional local testing)
VITE_ENFORCE_PLAN=true

# Tier gate QA harness (Node scripts only — never expose service role to browser)
SUPABASE_SERVICE_ROLE_KEY=
QA_TEST_PASSWORD=Password123!
APP_URL=http://localhost:5173

# Supabase Edge Function secrets (set in Supabase dashboard — NOT in frontend)
# STRIPE_SECRET_KEY=sk_test_... or sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_test_... or pk_live_...  (optional server-side mode cross-check)
# STRIPE_WEBHOOK_SECRET=whsec_...                    (must match test or live webhook endpoint)
# STRIPE_MODE=test                                     (or live — must match sk_/pk_ prefix)
# APP_URL=https://app.ardenprojectos.com             (production)
# SUPABASE_SERVICE_ROLE_KEY=
