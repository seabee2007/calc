# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (frontend — publishable key only)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
VITE_APP_URL=http://localhost:5173

# Entitlements (optional local testing)
VITE_ENFORCE_PLAN=true

# Tier gate QA harness (Node scripts only — never expose service role to browser)
SUPABASE_SERVICE_ROLE_KEY=
QA_TEST_PASSWORD=Password123!
APP_URL=http://localhost:5173

# Supabase Edge Function secrets (set in Supabase dashboard — NOT in frontend)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# APP_URL=
# SUPABASE_SERVICE_ROLE_KEY=