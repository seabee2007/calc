{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://concretecalc.app/schemas/productionRate.schema.json",
  "title": "ExtractedProductionRateRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceDocumentCode",
    "division",
    "divisionName",
    "figure",
    "activityName",
    "unitOfMeasure",
    "sourcePage",
    "confidence"
  ],
  "properties": {
    "sourceDocumentCode": {
      "type": "string",
      "const": "MCRP 3-40D.12"
    },
    "division": {
      "type": "string",
      "pattern": "^\\d{2}$"
    },
    "divisionName": {
      "type": "string",
      "minLength": 1
    },
    "figure": {
      "type": "string",
      "pattern": "^Figure 5-[A-Z]-\\d+$"
    },
    "figureTitle": {
      "type": ["string", "null"]
    },
    "workElementNumber": {
      "type": ["string", "null"],
      "pattern": "^\\d{2}\\s\\d{2}\\s\\d{2}\\.\\d{2}$"
    },
    "workElementLineNumber": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}$"
    },
    "activityName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"]
    },
    "unitOfMeasure": {
      "type": "string",
      "minLength": 1
    },
    "manHoursPerUnit": {
      "type": ["number", "null"]
    },
    "crewSize": {
      "type": ["number", "null"]
    },
    "skilledTrade": {
      "type": ["string", "null"]
    },
    "laborerCount": {
      "type": ["number", "null"]
    },
    "equipment": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "sourcePage": {
      "type": "string",
      "minLength": 1
    },
    "sourcePdfPage": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["raw", "needs_review", "reviewed", "approved"]
    },
    "fabricateHours": {
      "type": ["number", "null"]
    },
    "erectStripHours": {
      "type": ["number", "null"]
    },
    "cleanMoveHours": {
      "type": ["number", "null"]
    },
    "extractionWarnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
